<html   lang="eng"
		data="((Custom.Dir))\db\data-readme.xml"
		loc="((Custom.Dir))\data\jcr_root\content\canadasite\en\revenue-agency\services\forms-publications\previous-year-forms-publications\"
		title="((name)).ToUpper() ARCHIVED - ((title))"
		fileName="archived-((name))"
		mode="replace"
		replaceChildrenAEM="false"
		overrideDate="true"
		depth="2"
		contentTypes="guidance">
	  
	<header>
		<title>((name)).ToUpper() ARCHIVED &#8212; ((title))</title>
		<altTitle source="((Custom.Key))" remove="-e" add="-f" type="end">((name)).ToUpper() ARCHIV&#201;E - ((title))</altTitle>
		<unique val="e@@true@@true">((language))@@((pub))@@((priorYear))</unique>
		<excludes val="t2203@@rc4018@@t4008@@t4032@@t4127">((name))@@((name))@@((name))@@((name))@@((name))</excludes>
		<meta name="keywords">((keywords))</meta>
		<meta name="description">((description))</meta>
		<meta name="subject">((subject))</meta>
		<meta name="gcAltLanguagePeer">/content/canadasite/fr/agence-revenu/services/formulaires-publications/formulaires-publications-annees-passees/archivee-((name)).html</meta>
		<meta name="contributor">((contributor))</meta>
		<meta name="contentprovider">((contentprovider))</meta>
		<meta name="otherName">archivee-((name))</meta>
		<meta name="otherPath">/content/canadasite/fr/agence-revenu/services/formulaires-publications/formulaires-publications-annees-passees/</meta>
        <meta name="gcModifiedOverride" format="yyyy-MM-dd">((pubDate))</meta>		
	</header>
	
	<generic-text>
		<h1 id="wb-cont">ARCHIVED - ((name)).ToUpper() ((title))</h1>
		<!--Rescue link-->
	  	<section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pub/((name)).txt#((name))-rescue-eng"></section>
	  <!--Alert space-->
	  <div required="notice">((notice))</div>
		<section required="ajaxid" data-ajax-replace="/content/dam/cra-arc/formspubs/include/((ajaxid)).txt#((ajaxid))-eng"></section>
	  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pub/((name)).txt#((name))-eng"></section>
		  <!--Description-->
	  <p required="description" class="mrgn-bttm-md">((description))</p>
	  <!--Ways to access the information-->
	  <h2 required="((html)) || ((pdf)) || ((largePrint))">Ways to access the information</h2>
	  <ul class="fa-ul">
<!--Flat-->
		<li required="((html)) || ((pdf)) || ((largePrint))"><span class="far fa-file-alt text-muted fa-lg fa-li"></span>
      <h3>Read the publication</h3>
		 <ul>
			<li required="html">Online format <a href="/content/canadasite/en/revenue-agency/services/forms-publications/publications/((name))/((html)).HTMLFix()">((name))-e.html</a></li>
			<li required="pdf" split=";" sub=":" source="((pdf))">PDF <a href="/content/dam/cra-arc/formspubs/pub/((name))/((1))">((1))</a></li>
			 <li required="largePrint" split=";" sub=":" source="((largePrint))">Large print <a href="/content/dam/cra-arc/formspubs/pub/((name))/((1))">((1))</a></li>
		  </ul>
		  <details required="priorYear" class="max-content mrgn-tp-md mrgn-lft-md">
			<summary required="priorYear">Previous years: Standard print PDFs</summary>
			<p required="priorYear">This form is also available for the years listed below:</p>
			<ul required="priorYear" class="lst-none">
			  <li required="((pub)) %% ((priorYear))" split=";" sub=":" source="((priorYear))" sort="1;desc" hash="{'Standard print PDF':'.pdf'}" exclude="-fill-;-lp-;.txt;.brf"><a href="/content/dam/cra-arc/formspubs/pub/((name))/((2))">((1)) &#8211; ((Custom.Hash)) (((2)))</a></li>
			</ul>
		  </details>
			</li>	
			
				<!--E-text-->
		<li required="eText"><span class="fas fa-volume-up text-muted fa-lg fa-li"></span>
		  <h3>Download and listen</h3>
		  <p>Use your preferred screen reader to listen to the e-text file.</p>
		  <ul>
			<li required="eText" split=";" sub=":" source="((eText))"><a href="/content/dam/cra-arc/formspubs/pub/((name))/((1))">E-text (((1)))</a></li>
		  </ul>
		</li>
		<!--Order Alt Format-->
		<li required="((pdf)) || ((pdfFillable))"><span class="fas fa-universal-access text-muted fa-lg fa-li"></span>
		  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/altformat.txt#altformat-eng">
		  <h3>Ask for an alternate format</h3>
		  <p>You can order a digital audio, e-text, braille or large print version of this publication to be sent to you by mail.</p>
		  <ul>
			  <li>
			  <a href="/content/canadasite/en/revenue-agency/services/forms-publications/help-forms-publications/about-multiple-formats.html">Order alternate formats for persons with disabilities</a></li>
		  </ul> 
		  </section>
		</li>
	  </ul>
	  <!--Instructions-->
	  <section data-ajax-replace="/content/canadasite/en/revenue-agency/services/forms-publications/publications/((name))/instructions.html#instr"></section>
	  <!--Related documents-->
	  <h2 required="related_documents">Related documents</h2>
	  <ul required="related_documents">
		<li required="related_documents" split=";" sub="::" source="((related_documents))"><a href="((2))">((1))</a></li>
	  </ul>
	</generic-text>
</html>