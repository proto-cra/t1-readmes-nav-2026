<html   lang="eng"
		data="((Custom.Dir))\db\data-readme.xml"
		loc="((Custom.Dir))\data\jcr_root\content\canadasite\en\revenue-agency\services\forms-publications\publications\"
		title="((name)).ToUpper() ((title))"
		fileName="((name))"
		mode="multiple"
		replaceChildrenAEM="false"
		overrideDate="true"
		depth="2"
		contentTypes="guidance">
	
	<header>
		<title>((name)).ToUpper() ((title))</title>
		<altTitle source="((Custom.Key))" remove="-e" add="-f" type="end">((name)).ToUpper() ((title))</altTitle>
		<unique val="e@@true@@true@@">((language))@@((pub))@@((currentVersion))@@((revMonth))</unique>
		<includes val="ic*">((name))</includes>
		<meta name="keywords">((keywords))</meta>
		<meta name="description">((description))</meta>
		<meta name="subject">((subject))</meta>
		<meta name="contributor">((contributor))</meta>
		<meta name="contentprovider">((contentprovider))</meta>
		<meta name="gcAltLanguagePeer">/content/canadasite/fr/agence-revenu/services/formulaires-publications/publications/((name)).html</meta>
		<meta name="otherName">((name))</meta>
		<meta name="otherPath">/content/canadasite/fr/agence-revenu/services/formulaires-publications/publications/</meta>
        <meta name="gcModifiedOverride" format="yyyy-MM-dd">((pubDate))</meta>	
	</header>

	<generic-text>
		<h1 id="wb-cont">((name)).ToUpper() ((title))</h1>
		<!--Rescue link-->
	  	<section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pub/((name)).txt#((name))-rescue-eng"></section>
	  	<!--Alert space-->
		<div required="notice">((notice))</div>
		<section required="ajaxid" data-ajax-replace="/content/dam/cra-arc/formspubs/include/((ajaxid)).txt#((ajaxid))-eng"></section>
		<section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pub/((name)).txt#((name))-eng"></section>
	</generic-text>

	<text-wrapper>
		<p required="((pdf)) || ((html))">You can <strong>view</strong> this publication in:</p>
		
		<ul required="((pdf)) || ((html))" class="lst-none">
			<li required="html">HTML <a href="/content/canadasite/en/revenue-agency/services/forms-publications/publications/((name))/((html)).HTMLFix()">((name))-e.html</a></li>
			<li required="pdf" split=";" sub=":" source="((pdf))">PDF <a href="/content/dam/cra-arc/formspubs/pub/((name))/((1))" download="((name))-((revYear))e.pdf">((name))-((revYear))e.pdf</a></li>
		</ul>

		<p required="((eText)) || ((largePrint)) || ((braille))">For people with visual impairments, the following alternate formats are also available:</p>
		
		<ul required="((eText)) || ((largePrint)) || ((braille))" class="lst-none">
			<li required="eText" split=";" sub=":" source="((eText))">E-text <a href="/content/dam/cra-arc/formspubs/pub/((name))/((1))" download="((name))-((revYear))e.txt">((name))-((revYear))e.txt</a></li>
			<li required="largePrint" split=";" sub=":" source="((largePrint))">Large print <a href="/content/dam/cra-arc/formspubs/pub/((name))/((1))" download="((name))-lp-((revYear))e.pdf">((name))-lp-((revYear))e.pdf</a></li>
			<li required="braille" split=";" sub=":" source="((braille))">Braille <a href="/content/dam/cra-arc/formspubs/pub/((name))/((1))" download="((name))-((revYear))e.brf">((name))-((revYear))e.brf</a></li>
		</ul>
			
		<p required="pubDate"><strong>Last update:</strong> ((pubDate))</p>

		<p required="priorYear"><a href="/content/canadasite/en/revenue-agency/services/forms-publications/previous-year-forms-publications/archived-((name)).html">Previous-year versions</a> are also available.</p>
		
		<p required="related_documents"><strong>Related documents:</strong></p>

		<ul required="related_documents" class="list-unstyled">
			<li required="related_documents" split=";" sub="::" source="((related_documents))"><a href="((2))">((1))</a></li>
		</ul>
	</text-wrapper>
	
	<generic-text>
		<section data-ajax-replace="/content/dam/cra-arc/formspubs/include/footer.txt#footer-eng"></section>	
	</generic-text>

</html>