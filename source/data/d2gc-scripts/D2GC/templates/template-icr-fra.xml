<html   lang="fra"
		data="((Custom.Dir))\db\data-readme.xml"
		loc="((Custom.Dir))\data\jcr_root\content\canadasite\fr\agence-revenu\services\formulaires-publications\publications\"
		title="((name)).ToUpper()R((revMonth)) ((title))"
		fileName="((name))"
		mode="multiple"
		replaceChildrenAEM="false"
		overrideDate="true"
		depth="2"
		contentTypes="guidance">

	<header>
		<title>((name)).ToUpper()R((revMonth)) ((title))</title>
		<altTitle source="((Custom.Key))" remove="-f" add="-e" type="end">((name)).ToUpper()R((revMonth)) ((title))</altTitle>
		<unique val="f@@true@@true@@true">((language))@@((pub))@@((currentVersion))@@((revMonth))</unique>
		<includes val="ic*">((name))</includes>
		<meta name="keywords">((keywords))</meta>
		<meta name="description">((description))</meta>
		<meta name="subject">((subject))</meta>
		<meta name="contributor">((contributor))</meta>
		<meta name="contentprovider">((contentprovider))</meta>
		<meta name="gcAltLanguagePeer">/content/canadasite/en/revenue-agency/services/forms-publications/publications/((name)).html</meta>
		<meta name="otherName">((name))</meta>
		<meta name="otherPath">/content/canadasite/en/revenue-agency/services/forms-publications/publications/</meta>
        <meta name="gcModifiedOverride" format="yyyy-MM-dd">((pubDate))</meta>	
	</header>
	
	<generic-text>
		<h1 id="wb-cont">((name)).ToUpper()R((revMonth)) ((title))</h1>
		<!--Rescue link-->
	 	<section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pub/((name)).txt#((name))-rescue-fra"></section>
		<!--Alert space-->
		<div required="notice">((notice))</div>
		<section required="ajaxid" data-ajax-replace="/content/dam/cra-arc/formspubs/include/((ajaxid)).txt#((ajaxid))-fra"></section>
		<section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pub/((name)).txt#((name))-fra"></section>
	</generic-text>

	<text-wrapper>
		<p required="((pdf)) || ((html))">Vous pouvez <strong>voir</strong> la publication :</p>
		
		<ul required="((pdf)) || ((html))" class="lst-none">
			<li required="html">HTML <a href="/content/canadasite/fr/agence-revenu/services/formulaires-publications/publications/((name))/((html)).HTMLFix()">((name))r((revMonth))-f.html</a></li>
			<li required="pdf" split=";" sub=":" source="((pdf))">PDF <a href="/content/dam/cra-arc/formspubs/pub/((name))/((1))" download="((name))r((revMonth))-((revYear))f.pdf">((name))r((revMonth))-((revYear))f.pdf</a></li>
		</ul>

		<p required="((eText)) || ((largePrint)) || ((braille))">Les personnes ayant une d&#233;ficience visuelle peuvent aussi se procurer des versions dans les m&#233;dias substituts suivants :</p>
		
		<ul required="((eText)) || ((largePrint)) || ((braille))" class="lst-none">
			<li required="eText" split=";" sub=":" source="((eText))">Texte &#233;lectronique <a href="/content/dam/cra-arc/formspubs/pub/((name))/((1))" download="((name))r((revMonth))-((revYear))f.txt">((name))r((revMonth))-((revYear))f.txt</a></li>
			<li required="largePrint" split=";" sub=":" source="((largePrint))">Gros caract&#232;res <a href="/content/dam/cra-arc/formspubs/pub/((name))/((1))" download="((name))r((revMonth))-lp-((revYear))f.pdf">((name))r((revMonth))-lp-((revYear))f.pdf</a></li>
			<li required="braille" split=";" sub=":" source="((braille))">Braille <a href="/content/dam/cra-arc/formspubs/pub/((name))/((1))" download="((name))r((revMonth))-((revYear))f.brf">((name))r((revMonth))-((revYear))f.brf</a></li>
		</ul>
			
		<p required="pubDate"><strong>Mise &#224; jour :</strong> ((pubDate))</p>

		<p required="priorYear">Les <a href="/content/canadasite/fr/agence-revenu/services/formulaires-publications/formulaires-publications-annees-passees/archivee-((name)).html">versions des ann&#233;es pass&#233;es</a> sont aussi disponibles.</p>
		
		<p required="related_documents"><strong>Documents connexes :</strong></p>
		<ul required="related_documents" class="list-unstyled">
			<li required="related_documents" split=";" sub="::" source="((related_documents))"><a href="((2))">((1))</a></li>
		</ul>
	</text-wrapper>
		
	<generic-text>	
		<section data-ajax-replace="/content/dam/cra-arc/formspubs/include/footer.txt#footer-fra"></section>
	</generic-text>
		
</html>








































