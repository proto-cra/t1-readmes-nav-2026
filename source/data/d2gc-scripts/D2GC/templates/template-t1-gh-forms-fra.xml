<!--
Current T1 forms template.
Created for t1-readmes-nav-2026 T1 form pages that only expose current-year links.
-->

<html   lang="fra"
		data="((Custom.Dir))\db\data-readme.xml"
		loc="((Custom.Dir))\data\jcr_root\content\canadasite\fr\agence-revenu\services\formulaires-publications\formulaires\"
		title="((name)).ToUpper() ((title))"
		fileName="((name))"
		mode="replace"
		replaceChildrenAEM="false"
		overrideDate="true"
		depth="2"
		contentTypes="forms">
	  
	<header>
		<title>((name)).ToUpper() ((title))</title>
		<altTitle source="((Custom.Key))" remove="-f" add="-e" type="end">((name)).ToUpper() ((title))</altTitle>
		<unique val="f@@true">((language))@@((pbg))</unique>
		<includes val="50*">((name))</includes>
		<meta name="keywords">((keywords))</meta>
		<meta name="description">((description))</meta>
		<meta name="subject">((subject))</meta>
		<meta name="gcAltLanguagePeer">/content/canadasite/en/revenue-agency/services/forms-publications/forms/((name)).html</meta>
		<meta name="otherName">((name))</meta>
		<meta name="otherPath">/content/canadasite/en/revenue-agency/services/forms-publications/forms/</meta>
		<meta name="contributor">((contributor))</meta>
		<meta name="contentprovider">((contentprovider))</meta>
		<meta name="gcModifiedOverride" format="yyyy-MM-dd">((pubDate))</meta>
	</header>
	
	<generic-text>
	  <h1 id="wb-cont">((name)).ToUpper() ((title))</h1>
	  <p class="small mrgn-tp-sm"><strong>Vous cherchez peut-&#234;tre : </strong> <a href="/content/canadasite/fr/agence-revenu/services/formulaires-publications/trousses-impot-toutes-annees-imposition/trousse-generale-impot-prestations.html">Obtenir une trousse d&#8217;imp&#244;t T1</a></p>
	  <div class="clearfix" aria-hidden="true"></div>
	  <!--Rescue link-->
	  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pbg/((name)).txt#((name))-rescue-fra"></section>
	  <!--Alert space-->
	  <div required="notice">((notice))</div>
	  <section required="ajaxid" data-ajax-replace="/content/dam/cra-arc/formspubs/include/((ajaxid)).txt#((ajaxid))-fra"></section>
	  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pbg/((name)).txt#((name))-fra"></section>
	  <!--PDF instructions-->
	  <section id="instructions" class="mfp-hide modal-dialog modal-content overlay-def">
		<header class="modal-header">
		  <h2 class="modal-title">Instructions pour t&#233;l&#233;charger les PDF &#224; remplir</h2>
		</header>
		<div class="modal-body">
		  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pdf-instructions.txt#pdf-forms-fra">
			<p class="mrgn-tp-md">Vous <strong>devez t&#233;l&#233;charger </strong> le PDF &#224; remplir accessible sur votre ordinateur. Utilisez <a href="https://get.adobe.com/fr/reader/">Acrobat Reader 10 ou une version ult&#233;rieure</a> pour ouvrir le fichier. Ne cliquez <strong>pas</strong> sur le lien pour l'ouvrir dans votre navigateur Web.</p>
			<ol>
			  <li>T&#233;l&#233;chargez et enregistrez le PDF sur votre ordinateur</li>
			  <li>Ouvrez le PDF t&#233;l&#233;charg&#233; dans Acrobat Reader 10 ou une version ult&#233;rieure</li>
			</ol>
		  </section>
		</div>
	  </section>
	  <!--Description-->
	  <p required="description" class="mrgn-bttm-md">((description))</p>
	  <!--Ways to get the form-->
		  <h2>Fa&#231;ons d'obtenir le formulaire</h2>
		  <div required="((currentversion)) == true %% true">
		    <p>Ce formulaire <strong>n&#8217;est plus &#224; jour</strong>. Les versions des ann&#233;es pr&#233;c&#233;dentes sont disponibles.</p>
	        <p>D&#233;couvrez comment utiliser les diff&#233;rents formats :</p>
		    <ul class="fa-ul">
			  <li><span class="fas fa-file-download text-muted fa-lg fa-li"></span> <strong>PDF &#224; remplir : </strong> <a class="wb-lbx"
	            href="#instructions">T&#233;l&#233;chargez le PDF &#224; remplir et <span class="nowrap">ouvrez-le<span
	            class="far fa-question-circle mrgn-lft-sm"></span></span></a> dans Acrobat Reader 10 ou dans une version plus r&#233;cente pour le remplir.</li>
	          <li><span class="fas fa-pencil-alt text-muted fa-lg fa-li"></span> <strong>PDF standard ou en gros caract&#232;res :</strong> Imprimez le PDF standard ou le PDF en gros caract&#232;res pour le remplir &#224; la main.</li>
	          <li><span class="fas fa-volume-up text-muted fa-lg fa-li"></span> <strong>Texte &#233;lectronique :</strong> T&#233;l&#233;chargez le fichier texte &#233;lectronique et utilisez le lecteur d'&#233;cran de votre choix pour l'&#233;couter. </li>
			</ul>
		  </div>
	  <ul class="fa-ul">
		<!--Online-->
		<li required="html"><span class="fas fa-laptop text-muted fa-lg fa-li"></span>
		  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pbg/((name)).txt#((name))-online-fra">
			<h3>Utilisez le formulaire en ligne</h3>
			<ul>
			  <li required="html" split=";" sub="::" source="((html))"><a href="((2))">((1)) (version Web)</a></li>
			</ul>
		  </section>
		</li>
		<!--Fillable-->
		<li required="pdfFillable"><span class="fas fa-file-download text-muted fa-lg fa-li"></span>
		  <h3>T&#233;l&#233;chargez le formulaire et <span class="nowrap">remplissez-le</span> &#224; l'aide d'Acrobat Reader</h3>
		  <p class="mrgn-bttm-md">Pour remplir le formulaire, vous <strong>devez </strong><a class="wb-lbx" href="#instructions">t&#233;l&#233;charger et ouvrir le formulaire PDF &#224; <span class="nowrap">remplir<span class="far fa-question-circle mrgn-lft-sm"></span></span></a> dans Acrobat Reader 10 ou dans une version plus r&#233;cente.</p>
		  <ul>
			<li required="pdfFillable" split=";" sub=":" source="((pdfFillable))"><a href="/content/dam/cra-arc/formspubs/pbg/((name))/((1))" download="((1))">PDF &#224; remplir <span class="wb-inv">accessible</span> (((1)))</a></li>
		  </ul>
		</li>
			<!--Flat-->
		<li required="((pdf)) || ((largePrint))"><span class="fas fa-pencil-alt text-muted fa-lg fa-li"></span>
		  <h3>Imprimez le formulaire et <span class="nowrap">remplissez-le</span> &#224; la main</h3>
		  <ul>
			<li required="pdf" split=";" sub=":" source="((pdf))"><a href="/content/dam/cra-arc/formspubs/pbg/((name))/((1))">PDF en caract&#232;res standards (((1)))</a></li>
			<li required="largePrint" split=";" sub=":" source="((largePrint))"><a href="/content/dam/cra-arc/formspubs/pbg/((name))/((1))">PDF en gros caract&#232;res (((1)))</a></li>
		  </ul>
		</li>
			<!--E-text-->
		<li required="eText"><span class="fas fa-volume-up text-muted fa-lg fa-li"></span>
		  <h3>T&#233;l&#233;chargez le formulaire et &#233;coutez le texte</h3>
		  <p>Utilisez le lecteur d'&#233;cran de votre choix pour &#233;couter le fichier texte &#233;lectronique.</p>
		  <ul>
			<li required="eText" split=";" sub=":" source="((eText))"><a href="/content/dam/cra-arc/formspubs/pbg/((name))/((1))">Texte &#233;lectronique (((1)))</a></li>
		  </ul>
		</li>
			<!--Order Alt Format - when form is current-->
		<li required="((currentversion)) %% ((pdf)) || ((currentversion)) %% ((pdfFillable)) || ((currentversion)) %% ((largePrint)) || ((currentversion)) %% ((eText))"><span class="fas fa-universal-access text-muted fa-lg fa-li"></span>
		  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/altformat.txt#altformat-fra">
			<h3>Demandez le formulaire en format substitut</h3>
			<p>Vous pouvez commander le formulaire en d'autres formats, comme en fichier audio num&#233;rique, en texte &#233;lectronique, en braille et en gros caract&#232;res.</p>
			<ul>
			  <li><a href="/content/canadasite/fr/agence-revenu/services/formulaires-publications/aide-formulaires-publications/a-propos-formats-alternatifs-substituts.html" class="nowrap">Commander des formats substituts pour les personnes handicap&#233;es</a></li>
			</ul>
		  </section>
		</li>
		<!-- Previous year versions section -->
		<li required="recentPriorYears"><span class="fas fa-history text-muted fa-lg fa-li"></span>
		  <h3 id="prvs-yrs">Obtenez une version des 9 ann&#233;es pr&#233;c&#233;dentes &#40;<span>((upname))</span>&#41;</h3>
          <p>Entrez l'<strong>ann&#233;e</strong> dans le filtre pour trouver le <strong>bon</strong> formulaire.</p>
		  <section data-wb-jsonmanager='{
			  "url": "{{ site.baseurl }}/source/data/forms-json/table-data/((name))-table-data.json#/data",
			  "name": "forms"}'></section>
		  <section class="table-responsive mrgn-tp-lg">
			<table class="wb-tables table table-striped table-condensed table-hover filterEmphasis provisional" id="year-filter"
data-wb-json='{
  "url": "#[forms]",
  "source": "#tbl2",
  "tobeclone": "tr",
  "mapping": [{
	  "selector": "th:nth-child(1)",
	  "value": "/year",
	  "placeholder": "[[year]]"
	},
	{
	  "selector": "td:nth-child(2)>a>span",
	  "value": "/fill_pdf_fr/0"
	},
	{
	  "selector": "td:nth-child(2)>a",
	  "value": "/fill_pdf_fr/1",
	  "attr": "href"
	},
	{
	  "selector": "td:nth-child(3)>a",
	  "value": "/stnd_pdf_fr/0"
	},
	{
	  "selector": "td:nth-child(3)>a",
	  "value": "/stnd_pdf_fr/1",
	  "attr": "href"
	},
	{
	  "selector": "td:nth-child(4)>a",
	  "value": "/lrge_pdf_fr/0"
	},
	{
	  "selector": "td:nth-child(4)>a",
	  "value": "/lrge_pdf_fr/1",
	  "attr": "href"
	},
	{
	  "selector": "td:nth-child(5)>a",
	  "value": "/dwld_etx_fr/0"
	},
	{
	  "selector": "td:nth-child(5)>a",
	  "value": "/dwld_etx_fr/1",
	  "attr": "href"
	}
  ]
}'
data-wb-tables='{
  "ordering": true,
  "order": [
	[0, "desc"]
  ],
  "paging": false,
  "retrieve": true
}'>
			  <caption>
			  Formats disponibles pour les 9 ann&#233;es pr&#233;c&#233;dentes
			  (veuillez t&#233;l&#233;charger les fichiers PDF &#224; remplir et .txt avant l'utilisation)
			  </caption>
			  <thead>
				<tr>
				  <th scope="col">Ann&#233;e</th>
				  <th scope="col">PDF &#224; remplir</th>
				  <th scope="col">PDF standard</th>
				  <th scope="col">PDF en gros caract&#232;res</th>
				  <th scope="col">Texte &#233;lectronique</th>
				</tr>
			  </thead>
			  <tbody>
			  </tbody>
			</table>
		  </section>
		  <template id="tbl2">
			<table>
			  <tr>
				<th scope="row">[[year]]</th>
				<td><a class="small"><span class="nowrap"></span></a></td>
				<td><a class="small"></a></td>
				<td><a class="small"></a></td>
				<td><a class="small"></a></td>
			  </tr>
			</table>
		  </template>
		  <button type="button" class="btn btn-default mrgn-tp-md" data-wb-doaction='{ "action": "tblfilter", "source": "#year-filter", "column": 0, "value": "" }'>R&#233;initialiser le filtre</button>
		  <!-- URL mapping, a central management to avoid racing condition -->
		  <section data-wb-urlmapping='{
  "yr": [{
	  "action": "tblfilter",
	  "source": "#year-filter",
	  "column": 0,
	  "value": "{qval}",
	  "match": "^[1-2][0-9][0-9][0-9]$",
	  "default": " "
	},
	{
	  "action": "patch",
	  "source": "#define-the-year",
	  "base": "/years",
	  "match": "^[0-9][0-9][0-9][0-9]$",
	  "default": "0000",
	  "patches": [{
		"op": "copy",
		"from": "/years/{qval}",
		"path": "/select/year"
	  }]
	}
  ],
  "rgn": [{
	"action": "patch",
	"source": "#define-the-region",
	"base": "/regions",
	"match": "^[a-z][a-z]$",
	"default": "ni",
	"patches": [{
	  "op": "copy",
	  "from": "/regions/{qval}",
	  "path": "/select/region"
	}]
  }],
  "multiplequery": true
}'></section>
		  <!-- Data source -->
		  <section id="sourceData" data-wb-jsonmanager='{
	"url": "{{ site.baseurl }}/source/data/yr-prov.json",
	"patches": {
	  "op": "add",
	  "path": "/select",
	  "value": {
		"region": ["", "", "", ""]
	  }
  },
  "name": "sourceData",
  "debug": false
}
'></section>
		  <!-- Manager to receive the URL mapping update from the "year" parameter -->
		  <section id="define-the-year" data-wb-jsonmanager-reload="true" data-wb-jsonmanager='{
  "url": "#[sourceData]",
  "wait": true,
  "name": "year-set",
  "debug": false
}
'></section>
		  <section id="define-the-region" data-wb-jsonmanager-reload="true" data-wb-jsonmanager='{
  "url": "#[sourceData]",
  "name": "region-set",
  "debug": false
}
'></section>
		  <!-- Final JSON manager that assemble the paralel operation, This ensure that all operations are completed before to proceed, so this avoid a race condition -->
		  <section data-wb-jsonmanager='{
  "url": [{
	"url": "#[year-set]/select"
  }, {
	"url": "#[region-set]/select"
  }],
  "name": "find-other-form",
  "patches": {
	"op": "add",
	"path": "/emptystr",
	"value": "",
	"rfds:label": "This patch is used as an helper to render the paragraph visibility"
  },
  "debug": false
}
'></section>
		  <!-- Render the personalized paragraph content, also it will only being display if valid info was provided -->
		  <section data-wb-json='{
  "url": "#[find-other-form]",
  "streamline": true,
  "template": "template",
  "mapping": [{
	  "selector": "[data-year]",
	  "value": "/year"
	},
	{
	  "selector": "[data-region]",
	  "value": "/region/1"
	},
	{
	  "selector": "[data-anchor]",
	  "value": "/year",
	  "placeholder": "[[years]]"
	},
	{
	  "selector": "[data-anchor]",
	  "value": "/region/1",
	  "placeholder": "[[regions]]"
	},
	{
	  "selector": "[data-anchor]",
	  "value": "/year",
	  "attr": "href",
	  "placeholder": "--years--"
	},
	{
	  "selector": "[data-anchor]",
	  "value": "/region/3",
	  "attr": "href",
	  "placeholder": "--regions--"
	},
	{
	  "rdfs:label": "Unhide if we do have a valid year value",
	  "test": "fn:isLiteral",
	  "assess": "/year",
	  "mapping": {
		"selector": "[data-paragraph]",
		"attr": "class",
		"placeholder": "- hidden -",
		"value": "/emptystr"
	  }
	},
	{
	  "rdfs:label": "Unhide if we do have a valid region value",
	  "test": "fn:getValue",
	  "assess": "/region/0",
	  "operand": "neq",
	  "expect": "",
	  "mapping": {
		"selector": "[data-paragraph]",
		"attr": "class",
		"placeholder": "* hidden *",
		"value": "/emptystr"
	  }
	}
  ]
}
'>
			<template>
			  <p data-paragraph="true" class="- hidden -* hidden *">Pour trouver d&#8217;autres formulaires ou guides de l'ann&#233;e <strong><span data-year="true">ann&#233;e</span></strong> dont vous pourriez avoir besoin <strong><span data-region="true">r&#233;gion</span></strong>, retournez &#224; la <a data-anchor="true" href="https://www.canada.ca/fr/agence-revenu/services/formulaires-publications/trousses-impot-toutes-annees-imposition/archivee-trousse-generale-impot-prestations---years----regions--.html">trousse d&#8217;imp&#244;t sur le revenu de [[years]] [[regions]]</a>.</p>
			</template>
		  </section>
		</li>
			<!--Order Alt Format - when form is **NOT** current-->
			<li required="((currentversion)) == true %% true"><span class="fas fa-universal-access text-muted fa-lg fa-li"></span>
		  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/altformat.txt#altformat-fra">
			<h3>Demandez le formulaire en format substitut</h3>
			<p>Vous pouvez commander le formulaire en d'autres formats, comme en fichier audio num&#233;rique, en texte &#233;lectronique, en braille et en gros caract&#232;res.</p>
			<ul>
			  <li><a href="/content/canadasite/fr/agence-revenu/services/formulaires-publications/aide-formulaires-publications/a-propos-formats-alternatifs-substituts.html" class="nowrap">Commander des formats substituts pour les personnes handicap&#233;es</a></li>
			</ul>
		  </section>
		</li>
		<!-- Archive block -->
		<li><span class="fas fa-archive text-muted fa-lg fa-li"></span>
		  <section data-ajax-replace="{{ site.baseurl }}/source/data/archived-lac.txt #lac-fr"></section>
		</li>
	  </ul>
	  <!--Related documents-->
	  <h2 required="related_documents">Documents connexes</h2>
	  <ul required="related_documents">
		<li required="related_documents" split=";" sub="::" source="((related_documents))"><a href="((2))">((1))</a></li>
	  </ul>
	</generic-text>
</html>
