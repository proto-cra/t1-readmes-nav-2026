<!--
Current T1 forms template.
Created for t1-readmes-nav-2026 T1 form pages that only expose current-year links.
-->

<html   lang="eng"
		data="((Custom.Dir))\db\data-readme.xml"
		loc="((Custom.Dir))\data\jcr_root\content\canadasite\en\revenue-agency\services\forms-publications\forms\"
		title="((name)).ToUpper() ((title))"
		fileName="((name))"
		mode="replace"
		replaceChildrenAEM="false"
		overrideDate="true"
		depth="2"
		contentTypes="forms">
	  
	<header>
		<title>((name)).ToUpper() ((title))</title>
		<altTitle source="((Custom.Key))" remove="-e" add="-f" type="end">((name)).ToUpper() ((title))</altTitle>
		<unique val="e@@true@@true">((language))@@((pbg))@@((currentVersion))</unique>
		<includes val="50*">((name))</includes>
		<meta name="keywords">((keywords))</meta>
		<meta name="description">((description))</meta>
		<meta name="subject">((subject))</meta>
		<meta name="gcAltLanguagePeer">/content/canadasite/fr/agence-revenu/services/formulaires-publications/formulaires/((name)).html</meta>
		<meta name="otherName">((name))</meta>
		<meta name="otherPath">/content/canadasite/fr/agence-revenu/services/formulaires-publications/formulaires/</meta>
		<meta name="contributor">((contributor))</meta>
		<meta name="contentprovider">((contentprovider))</meta>
		<meta name="gcModifiedOverride" format="yyyy-MM-dd">((pubDate))</meta>
	</header>
	
	<generic-text>
	  <h1 id="wb-cont">((name)).ToUpper() ((title))</h1>
	  <p class="small mrgn-tp-sm"><strong>You may be looking for:</strong> <a href="/content/canadasite/en/revenue-agency/services/forms-publications/tax-packages-years/general-income-tax-benefit-package.html">Get a T1 income tax package</a></p>
	  <div class="clearfix" aria-hidden="true"></div>
	  <!--Rescue link-->
	  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pbg/((name)).txt#((name))-rescue-eng"></section>
	  <!--Alert space-->
	  <div required="notice">((notice))</div>
	  <section required="ajaxid" data-ajax-replace="/content/dam/cra-arc/formspubs/include/((ajaxid)).txt#((ajaxid))-eng"></section>
	  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pbg/((name)).txt#((name))-eng"></section>
	  <!--PDF instructions-->
	  <section id="instructions" class="mfp-hide modal-dialog modal-content overlay-def">
		<header class="modal-header">
		  <h2 class="modal-title">Instructions for downloading fillable PDFs</h2>
		</header>
		<div class="modal-body">
		  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pdf-instructions.txt#pdf-forms-eng">
			<p class="mrgn-tp-md">To complete a fillable form, you <strong>must download</strong> the accessible fillable PDF to your computer. Use <a href="https://get.adobe.com/reader/">Acrobat Reader 10 or later</a> to open the file. Do <strong>not</strong> click the link to open it in your web browser.</p>
			<ol>
			  <li>Download and save the PDF to your computer</li>
			  <li>Open the downloaded PDF in Acrobat Reader 10 or later</li>
			</ol>
		  </section>
		</div>
	  </section>
	  <!--Description-->
	  <p required="description" class="mrgn-bttm-md">((description))</p>
	  <!--Ways to get the form-->
	  <h2 required="((pdfFillable)) || ((pdf)) || ((largePrint)) || ((html)) || ((eText))">Ways to get the form</h2>
	  <ul class="fa-ul">
		<!--Online-->
		<li required="html"><span class="fas fa-laptop text-muted fa-lg fa-li"></span>
		  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/pbg/((name)).txt#((name))-online-eng">
			<h3>Use the online form</h3>
			<ul>
			  <li required="html" split=";" sub="::" source="((html))"><a href="((2))">((1)) (web version)</a></li>
			</ul>
		  </section>
		</li>
		<!--Fillable-->
		<li required="pdfFillable"><span class="fas fa-file-download text-muted fa-lg fa-li"></span>
		  <h3>Download the current form and fill out using Acrobat Reader</h3>
		  <p class="mrgn-bttm-md">To complete a fillable form, you <strong>must</strong> <a class="wb-lbx" href="#instructions">download the fillable PDF and open <span class="nowrap">it<span class="far fa-question-circle mrgn-lft-sm"></span></span></a> in Acrobat Reader 10 or higher.</p>
		  <ul>
			<li required="pdfFillable" split=";" sub=":" source="((pdfFillable))"><a href="/content/dam/cra-arc/formspubs/pbg/((name))/((1))" download="((1))"><span class="wb-inv">Accessible</span> Fillable PDF (((1)))</a></li>
		  </ul>
		</li>
		<!--Flat-->
		<li required="((pdf)) || ((largePrint))"><span class="fas fa-pencil-alt text-muted fa-lg fa-li"></span>
		  <h3>Print the current form and fill out by hand</h3>
		  <ul>
			<li required="pdf" split=";" sub=":" source="((pdf))"><a href="/content/dam/cra-arc/formspubs/pbg/((name))/((1))">Standard print PDF (((1)))</a></li>
			<li required="largePrint" split=";" sub=":" source="((largePrint))"><a href="/content/dam/cra-arc/formspubs/pbg/((name))/((1))">Large print PDF (((1)))</a></li>
		  </ul>
		</li>
		<!--E-text-->
		<li required="eText"><span class="fas fa-volume-up text-muted fa-lg fa-li"></span>
		  <h3>Download the current form and listen</h3>
		  <p>Use your preferred screen reader to listen to the e-text file.</p>
		  <ul>
			<li required="eText" split=";" sub=":" source="((eText))"><a href="/content/dam/cra-arc/formspubs/pbg/((name))/((1))">E-text (((1)))</a></li>
		  </ul>
		</li>
		<!--Order Alt Format-->
		<li required="((pdf)) || ((pdfFillable)) || ((largePrint)) || ((eText))"><span class="fas fa-universal-access text-muted fa-lg fa-li"></span>
		  <section data-ajax-replace="/content/dam/cra-arc/formspubs/include/altformat.txt#altformat-eng">
			<h3>Ask for an alternate format</h3>
			<p>You can order alternate formats such as digital audio, electronic text, braille, and large print.</p>
			<ul>
			  <li><a href="/content/canadasite/en/revenue-agency/services/forms-publications/help-forms-publications/about-multiple-formats.html">Order alternate formats for persons with disabilities</a></li>
			</ul>
		  </section>
		</li>
		<!-- Previous year versions section. The condition excludes current T1 forms without live previous-year links. -->
		<li required="((name)) == 5009-r"><span class="fas fa-history text-muted fa-lg fa-li"></span>
		  <h3 id="prvs-yrs">Get a version from the 9 previous years (((name)).ToUpper())</h3>
		  <p>To ensure you access the <strong>correct</strong> form, enter the <strong>year</strong> in the table filter.</p>
		  <section data-wb-jsonmanager='{ "url": "{{ site.baseurl }}/source/data/forms-json/table-data/((name))-table-data.json#/data", "name": "forms" }'></section>
		  <section class="table-responsive mrgn-tp-lg">
			<table class="wb-tables table table-striped table-condensed table-hover filterEmphasis provisional" id="year-filter" data-wb-json='{ "url": "#[forms]", "source": "#tbl2", "tobeclone": "tr", "mapping": [{ "selector": "th:nth-child(1)", "value": "/year", "placeholder": "[[year]]" }, { "selector": "td:nth-child(2)>a", "value": "/fill_pdf_en/0" }, { "selector": "td:nth-child(2)>a", "value": "/fill_pdf_en/1", "attr": "href" }, { "selector": "td:nth-child(3)>a", "value": "/stnd_pdf_en/0" }, { "selector": "td:nth-child(3)>a", "value": "/stnd_pdf_en/1", "attr": "href" }, { "selector": "td:nth-child(4)>a", "value": "/lrge_pdf_en/0" }, { "selector": "td:nth-child(4)>a", "value": "/lrge_pdf_en/1", "attr": "href" }, { "selector": "td:nth-child(5)>a", "value": "/dwld_etx_en/0" }, { "selector": "td:nth-child(5)>a", "value": "/dwld_etx_en/1", "attr": "href" }] }'>
			  <caption>Previous-year versions of this form</caption>
			  <thead>
				<tr>
				  <th scope="col">Year</th>
				  <th scope="col">Fillable PDF</th>
				  <th scope="col">Standard print PDF</th>
				  <th scope="col">Large print PDF</th>
				  <th scope="col">E-text</th>
				</tr>
			  </thead>
			  <tbody>
				<template id="tbl2">
				  <tr>
					<th scope="row">[[year]]</th>
					<td><a href="">Fillable PDF</a></td>
					<td><a href="">Standard print PDF</a></td>
					<td><a href="">Large print PDF</a></td>
					<td><a href="">E-text</a></td>
				  </tr>
				</template>
			  </tbody>
			</table>
		  </section>
		</li>
	  </ul>
	  <!--Related documents-->
	  <h2 required="related_documents">Related documents</h2>
	  <ul required="related_documents">
		<li required="related_documents" split=";" sub="::" source="((related_documents))"><a href="((2))">((1))</a></li>
	  </ul>
	</generic-text>
</html>
