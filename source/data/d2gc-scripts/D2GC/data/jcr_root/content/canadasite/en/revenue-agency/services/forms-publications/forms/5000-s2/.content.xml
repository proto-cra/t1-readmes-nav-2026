                text="&lt;h1 id=&quot;wb-cont&quot; >5000-S2 Schedule 2 - Federal Amounts Transferred from your Spouse or Common-Law Partner (for all except QC and non-residents)&lt;/h1>&lt;p class=&quot;small text-muted&quot; >T1 template triggered and used.&lt;/p>&lt;p class=&quot;small mrgn-tp-sm&quot; >&lt;strong>You may be looking for: &lt;/strong>&lt;a href=&quot;/content/canadasite/en/revenue-agency/services/forms-publications/tax-packages-years/general-income-tax-benefit-package.html&quot; >Get a T1 income tax package&lt;/a>&lt;/p>&lt;div class=&quot;clearfix&quot; aria-hidden=&quot;true&quot; >&lt;/div>&lt;!--Rescue link-->&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/pbg/5000-s2.txt#5000-s2-rescue-eng&quot; >&lt;/section>&lt;!--Alert space-->&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/pbg/5000-s2.txt#5000-s2-eng&quot; >&lt;/section>&lt;!--PDF instructions-->&lt;section id=&quot;instructions&quot; class=&quot;mfp-hide modal-dialog modal-content overlay-def&quot; >&lt;header class=&quot;modal-header&quot; >&lt;h2 class=&quot;modal-title&quot; >Instructions for downloading fillable PDFs&lt;/h2>&lt;/header>&lt;div class=&quot;modal-body&quot; >&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/pdf-instructions.txt#pdf-forms-eng&quot; >&lt;p class=&quot;mrgn-tp-md&quot; >To complete a fillable form, you &lt;strong>must download&lt;/strong> the accessible fillable PDF to your computer. Use &lt;a href=&quot;https://get.adobe.com/reader/&quot; >Acrobat Reader 10 or later&lt;/a> to open the file. Do &lt;strong>not&lt;/strong> click the link to open it in your web browser.&lt;/p>&lt;ol>&lt;li>Download and save the PDF to your computer&lt;/li>&lt;li>Open the downloaded PDF in Acrobat Reader 10 or later&lt;/li>&lt;/ol>&lt;/section>&lt;/div>&lt;/section>&lt;!--Description-->&lt;p class=&quot;mrgn-bttm-md&quot; >Schedule 2 is used by individuals to calculate the federal amounts transferred from a spouse or common-law partner.&lt;/p>&lt;!--Ways to get the form-->&lt;h2>Ways to get the form&lt;/h2>&lt;ul class=&quot;fa-ul&quot; >&lt;!--Online-->&lt;!--Fillable-->&lt;li>&lt;span class=&quot;fas fa-file-download text-muted fa-lg fa-li&quot; >&lt;/span>&lt;h3>Download the current form and fill out using Acrobat Reader&lt;/h3>&lt;p class=&quot;mrgn-bttm-md&quot; >To complete a fillable form, you &lt;strong>must &lt;/strong>&lt;a class=&quot;wb-lbx&quot; href=&quot;#instructions&quot; >download the fillable PDF and open &lt;span class=&quot;nowrap&quot; >it&lt;span class=&quot;far fa-question-circle mrgn-lft-sm&quot; >&lt;/span>&lt;/span>&lt;/a> in Acrobat Reader 10 or higher.&lt;/p>&lt;ul>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5000-s2/5000-s2-fill-25e.pdf&quot; download=&quot;5000-s2-fill-25e.pdf&quot;>&lt;span class=&quot;wb-inv&quot;>Accessible&lt;/span> Fillable PDF (5000-s2-fill-25e.pdf)&lt;/a>&lt;/li>&lt;/ul>&lt;/li>&lt;!--Flat-->&lt;li>&lt;span class=&quot;fas fa-pencil-alt text-muted fa-lg fa-li&quot; >&lt;/span>&lt;h3>Print the current form and fill out by hand&lt;/h3>&lt;ul>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5000-s2/5000-s2-25e.pdf&quot;>Standard print PDF (5000-s2-25e.pdf)&lt;/a>&lt;/li>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5000-s2/5000-s2-lp-25e.pdf&quot;>Large print PDF (5000-s2-lp-25e.pdf)&lt;/a>&lt;/li>&lt;/ul>&lt;/li>&lt;!--E-text-->&lt;li>&lt;span class=&quot;fas fa-volume-up text-muted fa-lg fa-li&quot; >&lt;/span>&lt;h3>Download the current form and listen&lt;/h3>&lt;p>Use your preferred screen reader to listen to the e-text file.&lt;/p>&lt;ul>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5000-s2/5000-s2-25e.txt&quot;>E-text (5000-s2-25e.txt)&lt;/a>&lt;/li>&lt;/ul>&lt;/li>&lt;!--Order Alt Format - when form is current-->&lt;li>&lt;span class=&quot;fas fa-universal-access text-muted fa-lg fa-li&quot; >&lt;/span>&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/altformat.txt#altformat-eng&quot; >&lt;h3>Ask for an alternate format&lt;/h3>&lt;p>You can order alternate formats such as digital audio, electronic text, braille, and large print.&lt;/p>&lt;ul>&lt;li>&lt;a href=&quot;/content/canadasite/en/revenue-agency/services/forms-publications/help-forms-publications/about-multiple-formats.html&quot; >Order alternate formats for persons with disabilities&lt;/a>&lt;/li>&lt;/ul>&lt;/section>&lt;/li>&lt;!-- Previous year versions section -->&lt;li>&lt;span class=&quot;fas fa-history text-muted fa-lg fa-li&quot; >&lt;/span>&lt;h3 id=&quot;prvs-yrs&quot; >Get a version from the 9 previous years (&lt;span>5000-S2&lt;/span>)&lt;/h3>&lt;p>To ensure you access the &lt;strong>correct&lt;/strong> form, enter the &lt;strong>year &lt;/strong>in the table filter.&lt;/p>&lt;section data-wb-jsonmanager='{      &quot;url&quot;: &quot;{{ site.baseurl }}/source/data/forms-json/table-data/5000-s2-table-data.json#/data&quot;,      &quot;name&quot;: &quot;forms&quot;}' >&lt;/section>&lt;section class=&quot;table-responsive mrgn-tp-lg&quot; >&lt;table class=&quot;wb-tables table table-striped table-condensed table-hover filterEmphasis provisional&quot; id=&quot;year-filter&quot; data-wb-json='{   &quot;url&quot;: &quot;#&#91;forms&#93;&quot;,   &quot;source&quot;: &quot;#tbl2&quot;,   &quot;tobeclone&quot;: &quot;tr&quot;,   &quot;mapping&quot;: &#91;{    &quot;selector&quot;: &quot;th:nth-child(1)&quot;,    &quot;value&quot;: &quot;/year&quot;,    &quot;placeholder&quot;: &quot;&#91;&#91;year&#93;&#93;&quot;  },  {    &quot;selector&quot;: &quot;td:nth-child(2)&amp;gt;a&quot;,    &quot;value&quot;: &quot;/fill_pdf_en/0&quot;  },  {    &quot;selector&quot;: &quot;td:nth-child(2)&amp;gt;a&quot;,    &quot;value&quot;: &quot;/fill_pdf_en/1&quot;,    &quot;attr&quot;: &quot;href&quot;  },  {    &quot;selector&quot;: &quot;td:nth-child(3)&amp;gt;a&quot;,    &quot;value&quot;: &quot;/stnd_pdf_en/0&quot;  },  {    &quot;selector&qu