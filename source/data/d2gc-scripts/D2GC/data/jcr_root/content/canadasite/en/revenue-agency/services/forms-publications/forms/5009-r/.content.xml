                sling:resourceType="canada/components/content/mwsgeneric-base-html"
                text="&lt;h1 id=&quot;wb-cont&quot; >5009-R Income Tax and Benefit Return (for AB)&lt;/h1>&lt;p class=&quot;small text-muted&quot; >T1 template triggered and used.&lt;/p>&lt;p class=&quot;small mrgn-tp-sm&quot; >&lt;strong>You may be looking for: &lt;/strong>&lt;a href=&quot;/content/canadasite/en/revenue-agency/services/forms-publications/tax-packages-years/general-income-tax-benefit-package.html&quot; >Get a T1 income tax package&lt;/a>&lt;/p>&lt;div class=&quot;clearfix&quot; aria-hidden=&quot;true&quot; >&lt;/div>&lt;!--Rescue link-->&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/pbg/5009-r.txt#5009-r-rescue-eng&quot; >&lt;/section>&lt;!--Alert space-->&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/pbg/5009-r.txt#5009-r-eng&quot; >&lt;/section>&lt;!--PDF instructions-->&lt;section id=&quot;instructions&quot; class=&quot;mfp-hide modal-dialog modal-content overlay-def&quot; >&lt;header class=&quot;modal-header&quot; >&lt;h2 class=&quot;modal-title&quot; >Instructions for downloading fillable PDFs&lt;/h2>&lt;/header>&lt;div class=&quot;modal-body&quot; >&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/pdf-instructions.txt#pdf-forms-eng&quot; >&lt;p class=&quot;mrgn-tp-md&quot; >To complete a fillable form, you &lt;strong>must download&lt;/strong> the accessible fillable PDF to your computer. Use &lt;a href=&quot;https://get.adobe.com/reader/&quot; >Acrobat Reader 10 or later&lt;/a> to open the file. Do &lt;strong>not&lt;/strong> click the link to open it in your web browser.&lt;/p>&lt;ol>&lt;li>Download and save the PDF to your computer&lt;/li>&lt;li>Open the downloaded PDF in Acrobat Reader 10 or later&lt;/li>&lt;/ol>&lt;/section>&lt;/div>&lt;/section>&lt;!--Description-->&lt;!--Ways to get the form-->&lt;h2>Ways to get the form&lt;/h2>&lt;ul class=&quot;fa-ul&quot; >&lt;!--Online-->&lt;!--Fillable-->&lt;li>&lt;span class=&quot;fas fa-file-download text-muted fa-lg fa-li&quot; >&lt;/span>&lt;h3>Download the current form and fill out using Acrobat Reader&lt;/h3>&lt;p class=&quot;mrgn-bttm-md&quot; >To complete a fillable form, you &lt;strong>must &lt;/strong>&lt;a class=&quot;wb-lbx&quot; href=&quot;#instructions&quot; >download the fillable PDF and open &lt;span class=&quot;nowrap&quot; >it&lt;span class=&quot;far fa-question-circle mrgn-lft-sm&quot; >&lt;/span>&lt;/span>&lt;/a> in Acrobat Reader 10 or higher.&lt;/p>&lt;ul>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5009-r/5009-r-fill-25e.pdf&quot; download=&quot;5009-r-fill-25e.pdf&quot;>&lt;span class=&quot;wb-inv&quot;>Accessible&lt;/span> Fillable PDF (5009-r-fill-25e.pdf)&lt;/a>&lt;/li>&lt;/ul>&lt;/li>&lt;!--Flat-->&lt;li>&lt;span class=&quot;fas fa-pencil-alt text-muted fa-lg fa-li&quot; >&lt;/span>&lt;h3>Print the current form and fill out by hand&lt;/h3>&lt;ul>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5009-r/5009-r-25e.pdf&quot;>Standard print PDF (5009-r-25e.pdf)&lt;/a>&lt;/li>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5009-r/5009-r-lp-25e.pdf&quot;>Large print PDF (5009-r-lp-25e.pdf)&lt;/a>&lt;/li>&lt;/ul>&lt;/li>&lt;!--E-text-->&lt;li>&lt;span class=&quot;fas fa-volume-up text-muted fa-lg fa-li&quot; >&lt;/span>&lt;h3>Download the current form and listen&lt;/h3>&lt;p>Use your preferred screen reader to listen to the e-text file.&lt;/p>&lt;ul>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5009-r/5009-r-25e.txt&quot;>E-text (5009-r-25e.txt)&lt;/a>&lt;/li>&lt;/ul>&lt;/li>&lt;!--Order Alt Format - when form is current-->&lt;li>&lt;span class=&quot;fas fa-universal-access text-muted fa-lg fa-li&quot; >&lt;/span>&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/altformat.txt#altformat-eng&quot; >&lt;h3>Ask for an alternate format&lt;/h3>&lt;p>You can order alternate formats such as digital audio, electronic text, braille, and large print.&lt;/p>&lt;ul>&lt;li>&lt;a href=&quot;/content/canadasite/en/revenue-agency/services/forms-publications/help-forms-publications/about-multiple-formats.html&quot; >Order alternate formats for persons with disabilities&lt;/a>&lt;/li>&lt;/ul>&lt;/section>&lt;/li>&lt;!-- Previous year versions section -->&lt;!--Order Alt Format - when form is **NOT** current-->&lt;!-- Archive block -->&lt;li>&lt;span class=&quot;fas fa-archive text-muted fa-lg fa-li&quot; >&lt;/span>&lt;section data-ajax-replace=&quot;{{ site.baseurl }}/source/data/archived-lac.txt #lac-en&quot; >&lt;/section>&lt;/li>&lt;/ul>&lt;!--Related documents-->"/></par><par-right
