                sling:resourceType="canada/components/content/mwsgeneric-base-html"
                text="&lt;h1 id=&quot;wb-cont&quot; >5009-R Déclaration de revenus et de prestations (pour AB) - T1 Générale - 2025&lt;/h1>&lt;p class=&quot;small text-muted&quot; >Gabarit T1 déclenché et utilisé.&lt;/p>&lt;p class=&quot;small mrgn-tp-sm&quot; >&lt;strong>Vous cherchez peut-être : &lt;/strong>&lt;a href=&quot;/content/canadasite/fr/agence-revenu/services/formulaires-publications/trousses-impot-toutes-annees-imposition/trousse-generale-impot-prestations.html&quot; >Obtenir une trousse d’impôt T1&lt;/a>&lt;/p>&lt;div class=&quot;clearfix&quot; aria-hidden=&quot;true&quot; >&lt;/div>&lt;!--Rescue link-->&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/pbg/5009-r.txt#5009-r-rescue-fra&quot; >&lt;/section>&lt;!--Alert space-->&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/pbg/5009-r.txt#5009-r-fra&quot; >&lt;/section>&lt;!--PDF instructions-->&lt;section id=&quot;instructions&quot; class=&quot;mfp-hide modal-dialog modal-content overlay-def&quot; >&lt;header class=&quot;modal-header&quot; >&lt;h2 class=&quot;modal-title&quot; >Instructions pour télécharger les PDF à remplir&lt;/h2>&lt;/header>&lt;div class=&quot;modal-body&quot; >&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/pdf-instructions.txt#pdf-forms-fra&quot; >&lt;p class=&quot;mrgn-tp-md&quot; >Vous &lt;strong>devez télécharger &lt;/strong> le PDF à remplir accessible sur votre ordinateur. Utilisez &lt;a href=&quot;https://get.adobe.com/fr/reader/&quot; >Acrobat Reader 10 ou une version ultérieure&lt;/a> pour ouvrir le fichier. Ne cliquez &lt;strong>pas&lt;/strong> sur le lien pour l'ouvrir dans votre navigateur Web.&lt;/p>&lt;ol>&lt;li>Téléchargez et enregistrez le PDF sur votre ordinateur&lt;/li>&lt;li>Ouvrez le PDF téléchargé dans Acrobat Reader 10 ou une version ultérieure&lt;/li>&lt;/ol>&lt;/section>&lt;/div>&lt;/section>&lt;!--Description-->&lt;!--Ways to get the form-->&lt;h2>Façons d'obtenir le formulaire&lt;/h2>&lt;ul class=&quot;fa-ul&quot; >&lt;!--Online-->&lt;!--Fillable-->&lt;li>&lt;span class=&quot;fas fa-file-download text-muted fa-lg fa-li&quot; >&lt;/span>&lt;h3>Téléchargez le formulaire actuel et &lt;span class=&quot;nowrap&quot; >remplissez-le&lt;/span> à l'aide d'Acrobat Reader&lt;/h3>&lt;p class=&quot;mrgn-bttm-md&quot; >Pour remplir le formulaire, vous &lt;strong>devez &lt;/strong>&lt;a class=&quot;wb-lbx&quot; href=&quot;#instructions&quot; >télécharger et ouvrir le formulaire PDF à &lt;span class=&quot;nowrap&quot; >remplir&lt;span class=&quot;far fa-question-circle mrgn-lft-sm&quot; >&lt;/span>&lt;/span>&lt;/a> dans Acrobat Reader 10 ou dans une version plus récente.&lt;/p>&lt;ul>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5009-r/5009-r-fill-25f.pdf&quot; download=&quot;5009-r-fill-25f.pdf&quot;>PDF à remplir &lt;span class=&quot;wb-inv&quot;>accessible&lt;/span> (5009-r-fill-25f.pdf)&lt;/a>&lt;/li>&lt;/ul>&lt;/li>&lt;!--Flat-->&lt;li>&lt;span class=&quot;fas fa-pencil-alt text-muted fa-lg fa-li&quot; >&lt;/span>&lt;h3>Imprimez le formulaire actuel et &lt;span class=&quot;nowrap&quot; >remplissez-le&lt;/span> à la main&lt;/h3>&lt;ul>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5009-r/5009-r-25f.pdf&quot;>PDF en caractères standards (5009-r-25f.pdf)&lt;/a>&lt;/li>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5009-r/5009-r-lp-25f.pdf&quot;>PDF en gros caractères (5009-r-lp-25f.pdf)&lt;/a>&lt;/li>&lt;/ul>&lt;/li>&lt;!--E-text-->&lt;li>&lt;span class=&quot;fas fa-volume-up text-muted fa-lg fa-li&quot; >&lt;/span>&lt;h3>Téléchargez le formulaire actuel et écoutez le texte&lt;/h3>&lt;p>Utilisez le lecteur d'écran de votre choix pour écouter le fichier texte électronique.&lt;/p>&lt;ul>&lt;li>&lt;a href=&quot;/content/dam/cra-arc/formspubs/pbg/5009-r/5009-r-25f.txt&quot;>Texte électronique (5009-r-25f.txt)&lt;/a>&lt;/li>&lt;/ul>&lt;/li>&lt;!--Order Alt Format - when form is current-->&lt;li>&lt;span class=&quot;fas fa-universal-access text-muted fa-lg fa-li&quot; >&lt;/span>&lt;section data-ajax-replace=&quot;/content/dam/cra-arc/formspubs/include/altformat.txt#altformat-fra&quot; >&lt;h3>Demandez le formulaire en format substitut&lt;/h3>&lt;p>Vous pouvez commander le formulaire en d'autres formats, comme en fichier audio numérique, en texte électronique, en braille et en gros caractères.&lt;/p>&lt;ul>&lt;li>&lt;a href=&quot;/content/canadasite/fr/agence-revenu/services/formulaires-publications/aide-formulaires-publications/a-propos-formats-alternatifs-substituts.html&quot; class=&quot;nowrap&quot; >Commander des formats substituts pour les personnes handicapées&lt;/a>&lt;/li>&lt;/ul>&lt;/section>&lt;/li>&lt;!-- Previous year versions section -->&lt;!--Order Alt Format - when form is **NOT** current-->&lt;!-- Archive block -->&lt;li>&lt;span class=&quot;fas fa-archive text-muted fa-lg fa-li&quot; >&lt;/span>&lt;section data-ajax-replace=&quot;{{ site.baseurl }}/source/data/archived-lac.txt #lac-fr&quot; >&lt;/section>&lt;/li>&lt;/ul>&lt;!--Related documents-->"/></par><par-right
